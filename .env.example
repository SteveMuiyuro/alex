# GCP Project configuration
GOOGLE_CLOUD_PROJECT=alex-prod-project
VERTEX_REGION=us-east4
VERTEX_MODEL=gemini-2.5-flash

# Database
DATABASE_URL=postgresql+psycopg2://alex_app:CHANGE_ME@127.0.0.1:5432/alex
DB_NAME=alex

# Queue/Eventing
PUBSUB_TOPIC=projects/alex-prod-project/topics/alex-analysis-jobs

# Agent service endpoints (Cloud Run or local)
TAGGER_ENDPOINT=http://localhost:8001/tag
REPORTER_ENDPOINT=http://localhost:8002/report
CHARTER_ENDPOINT=http://localhost:8003/chart
RETIREMENT_ENDPOINT=http://localhost:8004/retirement

# Clerk
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# CORS
CORS_ORIGINS=http://localhost:3000
