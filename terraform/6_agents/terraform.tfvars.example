project_id = "alex-prod-project"
region     = "us-central1"

vertex_region = "us-east4"
vertex_model  = "gemini-2.5-flash"

db_user                  = "postgres"
db_password              = "CHANGE_ME"
db_name                  = "alex"
cloudsql_connection_name = "alex-prod-project:us-central1:alex-db"
openai_api_secret_name   = "openai-api-key"
langfuse_public_key_secret_name = ""
langfuse_secret_key_secret_name = ""
langfuse_base_url               = "https://us.cloud.langfuse.com"
polygon_api_key_secret_name     = ""
polygon_plan                    = "free"

# Optional per-agent images
agent_images = {
  planner    = "us-central1-docker.pkg.dev/alex-prod-project/alex/planner:latest"
  tagger     = "us-central1-docker.pkg.dev/alex-prod-project/alex/tagger:latest"
  reporter   = "us-central1-docker.pkg.dev/alex-prod-project/alex/reporter:latest"
  charter    = "us-central1-docker.pkg.dev/alex-prod-project/alex/charter:latest"
  retirement = "us-central1-docker.pkg.dev/alex-prod-project/alex/retirement:latest"
}
