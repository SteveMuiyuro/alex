project_id = "alex-prod-project"
region     = "us-central1"

frontend_bucket_name = "alex-prod-frontend"
api_image            = "us-central1-docker.pkg.dev/alex-prod-project/alex/api:latest"

database_url = "postgresql+psycopg2://alex_app:CHANGE_ME@<CLOUD_SQL_IP>:5432/alex"
pubsub_topic = "alex-analysis-jobs"

clerk_jwks_url = "https://your-app.clerk.accounts.dev/.well-known/jwks.json"
cors_origins = [
  "http://localhost:3000",
  "https://storage.googleapis.com/alex-prod-frontend"
]

vertex_model  = "gemini-2.5-flash"
vertex_region = "us-east4"
